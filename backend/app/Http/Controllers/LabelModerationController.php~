    public function bulkUpdate(Request $request)
    {
        $updates = $request->input('updates', []);

        foreach ($updates as $id => $fields) {
            $record = DB::table('ugc_label_moderations')->where('id', $id)->first();
            if (!$record)
                continue;

            $updateData = [];

            // L1 / L2 Moderation
            if (isset($fields['l1'])) {
                $updateData['label_category_L1_moderation'] = $fields['l1'];
            }
            if (isset($fields['l2'])) {
                $updateData['label_category_L2_moderation'] = $fields['l2'];
            }

            // Confidence Score
            if (isset($fields['confidence_score'])) {
                $updateData['confidence_score'] = $fields['confidence_score'];
            }

            // Convert Yes/No → approve/reject JSON
            $L1_status = ($updateData['label_category_L1_moderation'] ?? $record->label_category_L1_moderation) === 'Yes' ? 'reject' : 'approve';
            $L2_status = ($updateData['label_category_L2_moderation'] ?? $record->label_category_L2_moderation) === 'Yes' ? 'reject' : 'approve';

            $jsonData = [
                ['Level1' => $record->first_level_category_nameL1, 'status' => $L1_status],
                ['Level2' => $record->second_level_category_nameL2, 'status' => $L2_status],
            ];

            $updateData['L1_L2_moderation_json'] = json_encode($jsonData);
            $updateData['updated_at'] = now();

            DB::table('ugc_label_moderations')->where('id', $id)->update($updateData);
        }

        return response()->json(['status' => 'success', 'message' => 'All changes updated successfully!']);
    }


