    public function updateModeration(Request $request)
    {
        $validated = $request->validate([
            'id' => 'required|integer|exists:ugc_label_moderations,id',
            'type' => 'required|in:l1,l2',
            'value' => 'required|in:Yes,No',
        ]);

        // 🔹 Map Yes/No → Reject/Approve
        $moderationStatus = ($validated['value'] === 'Yes') ? 'reject' : 'approve';

        // 🔹 Determine which column to update
        $column = $validated['type'] === 'l1'
            ? 'label_category_L1_moderation'
            : 'label_category_L2_moderation';

        // 🔹 Fetch current record
        $record = DB::table('ugc_label_moderations')->where('id', $validated['id'])->first();
        if (!$record) {
            return response()->json([
                'status' => 'error',
                'message' => 'Record not found.'
            ], 404);
        }

        // 🔹 Prepare updated L1/L2 moderation values
        $label_category_L1_moderation = $validated['type'] === 'l1'
            ? $validated['value']
            : $record->label_category_L1_moderation;

        $label_category_L2_moderation = $validated['type'] === 'l2'
            ? $validated['value']
            : $record->label_category_L2_moderation;

        // 🔹 Build new JSON structure
        $L1_L2_moderation_json = json_encode([
            [
                'Level1' => $record->first_level_category_nameL1,
                'status' => ($label_category_L1_moderation === 'Yes') ? 'reject' : 'approve',
            ],
            [
                'Level2' => $record->second_level_category_nameL2,
                'status' => ($label_category_L2_moderation === 'Yes') ? 'reject' : 'approve',
            ]
        ]);

        // 🔹 Update both the moderation column + JSON
        DB::table('ugc_label_moderations')
            ->where('id', $validated['id'])
            ->update([
                $column => $validated['value'],
                'L1_L2_moderation_json' => $L1_L2_moderation_json,
                'updated_at' => now(),
            ]);

        return response()->json([
            'status' => 'success',
            'message' => ucfirst(str_replace('_', ' ', $column)) . ' updated successfully!'
        ]);
    }

