    public function store(Request $request)
    {
        // 🔹 Validate CSV file
        $validator = Validator::make($request->all(), [
            'csv_file' => 'required|file|mimes:csv,txt|max:10240',
        ]);

        if ($validator->fails()) {
            return response()->json([
                'status' => 'validation_error',
                'errors' => $validator->errors(),
            ], 422);
        }

        try {
            $file = $request->file('csv_file');
            $handle = fopen($file->getRealPath(), 'r');

            $header = fgetcsv($handle);
            if (!$header) {
                return response()->json(['status' => 'error', 'message' => 'CSV header missing'], 400);
            }

            $expected = [
                'label_name',
                'first_level_category_nameL1',
                'second_level_category_nameL2',
                'label_category_L1_moderation',
                'label_category_L2_moderation',
                'confidence_score'
            ];

            $missing = array_diff($expected, $header);
            if (!empty($missing)) {
                return response()->json(['status' => 'error', 'message' => 'Missing columns: ' . implode(', ', $missing)], 400);
            }

            $dataToInsert = [];
            $updateCount = 0;
            $insertCount = 0;

            while (($row = fgetcsv($handle)) !== false) {
                $row = array_combine($header, $row);

                $label_name = trim($row['label_name']);
                $first_level_category_nameL1 = trim($row['first_level_category_nameL1']);
                $second_level_category_nameL2 = trim($row['second_level_category_nameL2'] ?? '');
                $label_category_L1_moderation = strtolower(trim($row['label_category_L1_moderation'] ?? ''));
                $label_category_L2_moderation = strtolower(trim($row['label_category_L2_moderation'] ?? ''));
                $confidenceScore = isset($row['confidence_score']) ? (float) $row['confidence_score'] : null;

                // 🔹 Skip only if the required primary identifiers are missing
                if (!$label_name || !$first_level_category_nameL1) {
                    continue; // label_name and L1 are mandatory
                }

                // 🔹 Convert "yes"/"no" → "reject"/"approve"
                $label_category_L1_moderation_updated = match ($label_category_L1_moderation) {
                    'yes' => 'reject',
                    'no' => 'approve',
                    default => $label_category_L1_moderation ?: null,
                };

                $label_category_L2_moderation_updated = match ($label_category_L2_moderation) {
                    'yes' => 'reject',
                    'no' => 'approve',
                    default => $label_category_L2_moderation ?: null,
                };

                // 🔹 Build JSON safely (null-safe)
                $jsonArray = [];
                
                $jsonArray[] = [
                    'Level1' => $first_level_category_nameL1 ?? '',
                    'status' => $label_category_L1_moderation_updated ?? '',
                ];
            
                $jsonArray[] = [
                    'Level2' => $second_level_category_nameL2 ?? '',
                    'status' => $label_category_L2_moderation_updated ?? '',
                ];

                $first_level_second_level_json = json_encode($jsonArray);

                // 🔹 Check existing record
                $existing = DB::table('ugc_label_moderations')
                    ->where('label_name', $label_name)
                    ->where('first_level_category_nameL1', $first_level_category_nameL1)
                    ->where(function ($query) use ($second_level_category_nameL2) {
                        if ($second_level_category_nameL2) {
                            $query->where('second_level_category_nameL2', $second_level_category_nameL2);
                        }
                    })
                    ->first();

                if ($existing) {
                    // 🔹 Update existing record
                    DB::table('ugc_label_moderations')
                        ->where('id', $existing->id)
                        ->update([
                            'label_category_L1_moderation' => $label_category_L1_moderation ?: $existing->label_category_L1_moderation,
                            'label_category_L2_moderation' => $label_category_L2_moderation ?: $existing->label_category_L2_moderation,
                            'L1_L2_moderation_json' => $first_level_second_level_json,
                            'confidence_score' => $confidenceScore ?? $existing->confidence_score,
                            'updated_at' => now(),
                        ]);
                    $updateCount++;
                } else {
                    // 🔹 Insert new record
                    $dataToInsert[] = [
                        'label_name' => $label_name,
                        'first_level_category_nameL1' => $first_level_category_nameL1,
                        'second_level_category_nameL2' => $second_level_category_nameL2 ?: null,
                        'label_category_L1_moderation' => $label_category_L1_moderation ?: null,
                        'label_category_L2_moderation' => $label_category_L2_moderation ?: null,
                        'L1_L2_moderation_json' => $first_level_second_level_json ?: null,
                        'confidence_score' => $confidenceScore ?: null,
                        'created_at' => now(),
                        'updated_at' => now(),
                    ];
                }
            }

            fclose($handle);

            // 🔹 Bulk insert new records
            if (!empty($dataToInsert)) {
                DB::table('ugc_label_moderations')->insert($dataToInsert);
                $insertCount = count($dataToInsert);
            }

            // 🔹 Response handling
            if ($insertCount === 0 && $updateCount === 0) {
                return response()->json([
                    'status' => 'warning',
                    'message' => 'No new or updated records found in CSV.',
                ]);
            }

            $msgParts = [];
            if ($insertCount > 0)
                $msgParts[] = "$insertCount new records inserted";
            if ($updateCount > 0)
                $msgParts[] = "$updateCount records updated";

            return response()->json([
                'status' => 'success',
                'message' => implode(' and ', $msgParts) . ' successfully!',
            ]);
        } catch (\Throwable $e) {
            return response()->json([
                'status' => 'error',
                'message' => 'Something went wrong: ' . $e->getMessage(),
            ], 500);
        }
    }


    public function ajaxShowList(Request $request)
    {
        $query = LabelModeration::select('*')->where('is_deleted', 0)->orderBy('updated_at', 'desc'); // <-- ye line add karo

        // Apply column filters
        if ($request->has('columns')) {
            foreach ($request->get('columns') as $col) {
                $colName = $col['data'];
                $searchValue = $col['search']['value'];

                if (!empty($searchValue)) {
                    if ($colName === 'updated_at') {
                        // Date range filter
                        $dates = explode(' - ', $searchValue);
                        if (count($dates) === 2) {
                            $start = date('Y-m-d 00:00:00', strtotime($dates[0]));
                            $end = date('Y-m-d 23:59:59', strtotime($dates[1]));
                            $query->whereBetween('updated_at', [$start, $end]);
                        }
                    } else {
                        $query->where($colName, 'like', "%{$searchValue}%");
                    }
                }
            }
        }
        return DataTables::of($query)
            ->addIndexColumn()
            ->filterColumn('updated_at', function ($query, $keyword) {
                // yaha kuch bhi nahi karna because date range filter hum upar hi handle kar chuke hain
                // agar chaho to aap specific handling bhi kar sakte ho
            })
            ->editColumn('title', function ($row) {
                $titles = json_decode($row->title, true);
                return $titles[0]['title'] ?? $row->title;
            })
            ->addColumn('type', function ($row) {
                $titles = json_decode($row->title, true);
                return $titles[0]['language'] ?? '';
            })
            ->addColumn('action', function ($row) {
                return '
                    <div class="d-flex">
                        <!-- Circular icon-only version -->
                        <button class="btn btn-success btn-icon update-btn" data-id="' . $row->id . '" disabled>
                            <i class="fa fa-edit"></i>
                        </button>
                        <button type="button" class="btn btn-danger btn-icon" onclick="deleteRecord(' . $row->id . ')">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>

                ';
            })
            ->rawColumns(['status', 'action'])
            ->make(true);

    }

