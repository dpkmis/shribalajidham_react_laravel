    /**
     * Update the specified resource in storage.
     */
    public function update(Request $request, MasterGenre $MasterGenre)
    {
        // Validate incoming request
        $request->validate([
            // 'display_title' => 'required|string|max:255',
            'title' => 'required|array', // array of content + language
            'status' => 'required|boolean',
            'is_filter_tag' => 'required|boolean',
        ]);
        try {
            // Prepare title JSON
            $titleJson = json_encode($request->title);

            $englishData = array_filter($request->title, function($item) {
                return strtolower($item['language']) === 'english';
            });
            $englishData = array_values($englishData);
            if(!empty($englishData)){
                $display_title = $englishData[0]['content'];
            }else{
                $display_title = $request->title[0]['content'];
            }

            // Update the record
            $MasterGenre->update([
                'display_title' => $display_title,
                'title' => $titleJson,
                'status' => $request->status,
                'is_filter_tag' => $request->is_filter_tag,
                'modified_at' => now(),
            ]);

            return response()->json([
                'status' => 200,
                'message' => 'Genre updated successfully!',
            ]);
        } catch (\Exception $e) {
            return response()->json([
                'status' => 500,
                'message' => 'Something went wrong: ' . $e->getMessage(),
            ]);
        }
    }

    /**
     * Remove the specified resource from storage.
     */
    public function destroy(MasterGenre $MasterGenre)
    {
        try {
            // Update status to 2 (Deleted)
            $deleted = $MasterGenre->update([
                'status' => 2,
                'modified_at' => now(),
            ]);

            if ($deleted) {
                return response()->json([
                    'status' => 200,
                    'message' => 'Genre deleted successfully (soft delete).'
                ]);
            } else {
                return response()->json([
                    'status' => 404,
                    'message' => 'Genre not found.'
                ]);
            }
        } catch (\Exception $e) {
            return response()->json([
                'status' => 500,
                'message' => 'Something went wrong: ' . $e->getMessage(),
            ]);
        }
    }
